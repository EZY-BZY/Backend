# Application
APP_NAME=Supplier SaaS API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
VERSION=0.1.0
# Security (use a long random string in production)
SECRET_KEY=change-me-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# PostgreSQL (relational / ORM)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/supplier_saas
# If you use Docker Compose and another Postgres already uses 5432, map host port 5433 (see docker-compose) and use:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/supplier_saas
# POSTGRES_HOST_PORT=5433

# MongoDB (documents / flexible data)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=supplier_saas

# Redis (cache / pub-sub / queues)
REDIS_URL=redis://localhost:6379/0

# PDF templates (optional override; default is <project>/templates/pdf)
# PDF_TEMPLATES_DIR=/absolute/path/to/templates/pdf

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=true

# Media uploads (chunked writes under MEDIA_ASSETS_DIR or <project>/assets)
# ASSETS_URL_PATH_PREFIX must match the StaticFiles mount (default /api/v1/assets)
# MEDIA_ASSETS_DIR=
ASSETS_URL_PATH_PREFIX=/api/v1/assets
UPLOAD_CHUNK_SIZE_BYTES=1048576
MAX_IMAGE_UPLOAD_BYTES=15728640
MAX_VIDEO_UPLOAD_BYTES=209715200
MAX_GENERAL_FILE_UPLOAD_BYTES=52428800
ACCEPTED_IMAGE_TYPES=jpg,jpeg,png,webp
ACCEPTED_VIDEO_TYPES=mp4,mov,avi,webm
ACCEPTED_FILE_TYPES=pdf,doc,docx,xls,xlsx,csv,txt
MAX_BATCH_UPLOAD_FILES=40
